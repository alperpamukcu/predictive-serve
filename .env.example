# Copy this file to ".env" (do NOT commit .env)
# Then fill values.

# Sportradar Tennis API
SPORTRADAR_TENNIS_API_KEY=__PASTE_KEY_HERE__
# access_level: typically "trial" or "production"
SPORTRADAR_TENNIS_ACCESS_LEVEL=trial
# language_code: e.g. en
SPORTRADAR_TENNIS_LANG=en

# Upcoming fixtures window
UPCOMING_DAYS=14

# tennis-data.co.uk access (optional)
# If the host is geo-restricted, set an HTTPS proxy.
# Example: http://user:pass@proxyhost:port
TEN_DATA_PROXY=
TEN_DATA_TIMEOUT_S=30
TEN_DATA_RETRIES=3
TEN_DATA_BASE_URL=http://www.tennis-data.co.uk

# Sportradar historical sampling (A/B quality checks)
# Fetches last N days of completed matches into data/raw/sportradar_historical.csv
SR_HIST_DAYS=30

# Sportradar Odds Comparison Regular API (optional)
SPORTRADAR_ODDS_API_KEY=__PASTE_KEY_HERE__
# package_type: row or us
SPORTRADAR_ODDS_PACKAGE=row
# access_level: t (trial) or p (production)
SPORTRADAR_ODDS_ACCESS=t
# language_code: en
SPORTRADAR_ODDS_LANG=en
# odds_format: eu (decimal), us, uk
SPORTRADAR_ODDS_FORMAT=eu
# Tennis on Odds Comparison Regular (see OC /sports feed)
SPORTRADAR_ODDS_SPORT_ID=sr:sport:5

# Sportradar Images API (Getty) (optional)
SPORTRADAR_IMAGES_API_KEY=__PASTE_KEY_HERE__
# access_level: t (trial) or p (production)
SPORTRADAR_IMAGES_ACCESS=t
# provider: getty / getty_premium / reuters / ap / usat ...
SPORTRADAR_IMAGES_PROVIDER=getty
# sport: tennis
SPORTRADAR_IMAGES_SPORT=tennis
# league: leave empty for tennis (only used for soccer / getty golf)
SPORTRADAR_IMAGES_LEAGUE=
# Which year manifest to use (default: current year)
SPORTRADAR_IMAGES_MANIFEST_YEAR=2026

# Logos (optional; may require provider=ap for tennis)
SPORTRADAR_LOGOS_PROVIDER=ap
SPORTRADAR_LOGOS_MANIFEST_YEAR=2026


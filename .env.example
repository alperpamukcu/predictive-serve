# Copy this file to ".env" (do NOT commit .env)

# Upcoming fixtures window (days, 1..30)
UPCOMING_DAYS=14

# tennis-data.co.uk access (optional)
# Set an HTTPS proxy if the host is geo-restricted.
TEN_DATA_PROXY=
TEN_DATA_TIMEOUT_S=30
TEN_DATA_RETRIES=3
TEN_DATA_BASE_URL=http://www.tennis-data.co.uk

# API-Tennis (fixtures + odds + player logos)
API_TENNIS_KEY=__PASTE_KEY_HERE__
API_TENNIS_BASE_URL=https://api.api-tennis.com/tennis/
API_TENNIS_PROXY=
API_TENNIS_ODDS_MAX_ROWS=200
# On-disk cache TTL (seconds) for fixtures and odds responses.
API_TENNIS_CACHE_TTL_S=600
API_TENNIS_ODDS_CACHE_TTL_S=300
# Sleep between odds requests (ms) — protect rate limits.
API_TENNIS_ODDS_SLEEP_MS=250

# Refresh button cooldown (seconds)
REFRESH_COOLDOWN_S=120

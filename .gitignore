# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual Environment
.venv/
venv/
ENV/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local

# Jupyter Notebook
.ipynb_checkpoints/
*.ipynb_checkpoints

# ----------------------------------------------------------------------
# Data
# ----------------------------------------------------------------------
# Big raw archives & intermediate feature files: regenerable, not tracked.
data/raw/
data/processed/*
data/cache/*

# Live-served artifacts: tracked so the deployed app always has fresh data.
# (Daily refresh GitHub Action regenerates and commits these.)
!data/processed/all_predictions.csv
!data/processed/fixtures_upcoming.csv
!data/processed/.gitkeep
!data/cache/player_meta.json
!data/cache/.gitkeep

# Allow tracked examples / templates
!data/examples/
!data/examples/**

# ----------------------------------------------------------------------
# Models
# ----------------------------------------------------------------------
models/*.pkl
models/*.joblib
models/*.onnx
models/*.pt
# Keep these small artifacts so the deployed app can score on first boot.
!models/logreg_final.pkl
!models/imputer_final.pkl
!models/feature_columns.txt
!models/metrics.json

# Assets — track downloaded player photos so the deployed app shows them
# without needing API access. Tournament logos stay ignored for now.
assets/tournaments/*
!assets/tournaments/.gitkeep

# Logs
logs/
*.log

# Test coverage
.coverage
htmlcov/
.pytest_cache/

# OS
Thumbs.db
.DS_Store

# Temporary files
*.tmp
*.bak
*.swp

# Presentation visual generation scripts
create_additional_visuals.py
